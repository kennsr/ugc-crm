# Copy this file to .env.local and fill in the values
# NEVER commit .env.local

# Supabase — get from Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Database — get from Supabase Dashboard → Project Settings → Database → Connection Pooling
# Uses pgbouncer port 6543 for Prisma
DATABASE_URL=postgresql://postgres.your-project:YOUR-PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Server only — NEVER expose this to the client
# Get from Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Drive OAuth — get from Google Cloud Console
# Create OAuth 2.0 Client ID (Web application type)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/drive/callback

# App URL (for OAuth callback)
NEXT_PUBLIC_APP_URL=http://localhost:3000
